# App
SECRET_KEY=your-random-secret-key-here
DEBUG=false

# Auth (set AUTH_ENABLED=true for production)
AUTH_ENABLED=false
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Anthropic (optional — enables LLM ensemble classifier)
ANTHROPIC_API_KEY=sk-ant-...

# Database
DB_PATH=citizens.db

# Logging
LOG_LEVEL=INFO
LOG_FILE=
LOG_FORMAT=json

# Rate Limiting
RATE_LIMIT_CLASSIFY=30/minute
RATE_LIMIT_IMPORT=5/minute
RATE_LIMIT_DEFAULT=120/minute

# Classification
ESCALATION_THRESHOLD=0.65
HIGH_CONFIDENCE_THRESHOLD=0.8
HIGH_CONFIDENCE_MULTIPLIER=1.5

# Ingestion (optional)
TWITTER_BEARER_TOKEN=
TWITTER_TRACK_USERS=
TWITTER_RULES=
META_ACCESS_TOKEN=
META_APP_SECRET=
META_PAGE_IDS=
META_IG_USER_IDS=

# Gunicorn
GUNICORN_WORKERS=4
